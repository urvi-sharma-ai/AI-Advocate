# Copy this file to .env and fill in your values.

OPENAI_API_KEY=

# Where ChromaDB persists vectors.
CHROMA_PERSIST_DIR=.chroma
CHROMA_COLLECTION=legal_statutes

# OpenAI models.
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Chunks per embeddings API call (OpenAI caps total input tokens per request, e.g. ~300k).
EMBEDDING_BATCH_SIZE=100

# Data + manifest.
DATA_DIR=data
# Leave empty to use DATA_DIR/manifest.yaml (do not set to "." or leave accidental blanks that become cwd).
MANIFEST_PATH=

# Used by the routing prompt to interpret "this year".
# Example: 2026-05-20
REFERENCE_DATE=2026-05-20
